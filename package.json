{
  "name": "cockpit",
  "productName": "Cockpit",
  "version": "0.1.0",
  "private": true,
  "description": "Electron GUI wrapper for GitHub Copilot CLI.",
  "author": "Cockpit Contributors",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@primeuix/themes": "^2.0.3",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.9",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.7"
  },
  "overrides": {
    "app-builder-lib": {
      "minimatch": "^9.0.9"
    }
  },

  "build": {
    "appId": "com.cockpit.app",
    "productName": "Cockpit",
    "copyright": "Copyright © 2025 Cockpit Contributors",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-${arch}.dmg"
    },
    "linux": {
      "category": "Development",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "maintainer": "Cockpit Contributors",
      "description": "Desktop GUI for GitHub Copilot CLI"
    }
  }
}
